  "repository": {
    "type": "git",
    "url": "git+https://github.com/UseThatApp/javascript.git"
  },
  "bugs": {
    "url": "https://github.com/UseThatApp/javascript/issues"
  },
  "homepage": "https://github.com/UseThatApp/javascript",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test:compat": "node scripts/compat-test.mjs",
    "test:examples": "node scripts/example-tests.mjs",
    "test": "npm run build && npm run test:compat && npm run test:examples"
  },
  "devDependencies": {
